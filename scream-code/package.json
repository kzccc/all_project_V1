{
  "name": "@scream-cli/monorepo",
  "version": "0.6.7",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "build:packages": "pnpm -r --filter './packages/*' run build",
    "dev:cli": "pnpm -C apps/scream-code run dev",
    "typecheck": "pnpm run build:packages && pnpm -r --filter './packages/*' run typecheck && pnpm --filter scream-code run typecheck",
    "lint": "oxlint --type-aware",
    "lint:fix": "pnpm run lint --fix",
    "lint:pkg": "pnpm -r --filter '!@scream-cli/monorepo' exec publint && pnpm -r --filter './packages/*' exec attw --pack . --profile node16 --ignore-rules cjs-resolves-to-esm internal-resolution-error",
    "sherif": "sherif",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "pnpm -r run clean",
    "changeset": "changeset",
    "version": "changeset version",
    "version:release": "changeset version",
    "publish": "pnpm run typecheck && pnpm run lint && pnpm run sherif && pnpm run test && pnpm run build && pnpm run lint:pkg && changeset publish",
    "prepare": "node scripts/prepare.mjs"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.30.0",
    "@microsoft/api-extractor": "7.58.7",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "4.1.4",
    "lint-staged": "16.4.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "pkg-pr-new": "0.0.75",
    "publint": "0.3.18",
    "sherif": "1.11.1",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.22.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  },
  "simple-git-hooks": {},
  "pnpm": {
    "onlyBuiltDependencies": [
      "onnxruntime-node"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "oxlint --fix --quiet",
      "oxlint --type-aware --quiet"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
