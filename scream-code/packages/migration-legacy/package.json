{
  "name": "@scream-cli/migration-legacy",
  "version": "0.6.7",
  "description": "Migrate scream-cli (~/.scream/) data into scream-code (~/.scream-code/).",
  "license": "MIT",
  "type": "module",
  "private": true,
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@scream-cli/agent-core": "workspace:^",
    "smol-toml": "^1.6.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@scream-cli/jian": "workspace:^"
  }
}
